# Copy this file to .env and fill in the values before running docker-compose.
# On EC2 the monitoring-setup.sh writes .env automatically from Terraform outputs.

# Public or private IP of the Node.js application server (port 5000)
APP_SERVER_IP=

# Grafana admin password (avoid # and $ characters)
GRAFANA_ADMIN_PASSWORD=

# Email configuration for Alertmanager
ALERT_EMAIL_TO=admin@example.com
ALERT_EMAIL_FROM=alerts@example.com
ALERT_EMAIL_USERNAME=your-email@gmail.com
ALERT_EMAIL_PASSWORD=your-app-password
